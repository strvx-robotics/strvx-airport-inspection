# Backend service config. Copy to `.env` and fill in (never commit `.env`).
# These mirror the frontend's env so both services talk to the same Postgres.

# Postgres connection string (same DB as the frontend).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# TLS: the deployment Postgres (Supabase pooler) presents a self-signed chain,
# so verification is disabled here — exactly as the frontend does. To verify
# against a pinned CA instead, set DATABASE_CA_CERT (PEM) and leave this unset.
DATABASE_SSL_NO_VERIFY=1
# DATABASE_CA_CERT=

# Port this service listens on (frontend 3000, ml-service 8000, backend 8080).
BACKEND_PORT=8080

# Shared secret gating all routes except /health. UNSET = auth disabled (local
# dev/tests); production MUST set it. The frontend sends `Authorization: Bearer
# <token>` server-side. Generate with: openssl rand -hex 32
# BACKEND_API_TOKEN=

# Downstream services (used by later slices — uploads/drafting).
ML_SERVICE_URL=http://localhost:8000
# RL_SERVICE_URL=http://localhost:8000
# ANTHROPIC_API_KEY=
